aws_region         = "us-east-1"
environment        = "prod"
project            = "cloudbox"

# Networking
vpc_cidr           = "10.0.0.0/16"
availability_zones = ["us-east-1a", "us-east-1b", "us-east-1c"]

# EKS
cluster_version    = "1.30"
node_instance_type = "t3.medium"
node_min_size      = 2
node_max_size      = 6
node_desired_size  = 3

# RDS
db_instance_class  = "db.t3.medium"
db_name            = "cloudbox"
db_username        = "cloudbox"
db_password        = "CHANGE_ME_USE_SECRETS_MANAGER"
db_multi_az        = true

# ElastiCache
redis_node_type       = "cache.t3.micro"
redis_num_cache_nodes = 1

# S3 (must be globally unique)
s3_bucket_name = "cloudbox-files-prod-123456"

# DNS / TLS
domain_name         = "cloudbox.example.com"
acm_certificate_arn = ""   # Fill in after running: aws acm request-certificate
